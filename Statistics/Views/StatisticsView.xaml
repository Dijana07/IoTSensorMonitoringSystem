<Window x:Class="Statistics.Views.StatisticsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Statistics"
        Height="600"
        Width="1000"
        ResizeMode="NoResize">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="From:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <DatePicker SelectedDate="{Binding FromDate}"
                        Width="150"/>

            <TextBlock Text="To:"
                       VerticalAlignment="Center"
                       Margin="20,0,5,0"/>

            <DatePicker SelectedDate="{Binding ToDate}"
                        Width="150"/>

            <TextBlock Text="Source:"
                        VerticalAlignment="Center"
                        Margin="50,0,5,0"/>

            <ComboBox Width="120"
                        ItemsSource="{Binding DataSources}"
                        SelectedItem="{Binding SelectedDataSource}" />

            <Button Content="Load Data"
                        Width="120"
                        Margin="20,0,0,0"
                        Command="{Binding LoadDataCommand}" />

            <Button Content="Export CSV"
                        Width="120"
                        Margin="110,0,0,0"
                        Command="{Binding ExportCsvCommand}" />

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="Action:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <ComboBox Width="180"
                      ItemsSource="{Binding Strategies}"
                      SelectedItem="{Binding SelectedStrategy}" />

            <Button Content="Process Data"
                    Width="120"
                    Margin="10,0,0,0"
                    Command="{Binding ProcessDataCommand}" />

        </StackPanel>

        <GroupBox Header="Loaded data:"
          Grid.Row="2"
          Margin="0,10,0,10">

            <DataGrid ItemsSource="{Binding LoadedReadings}"
                AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="SensorId"
                        Binding="{Binding SensorId}" />

                    <DataGridTextColumn
                        Header="Values"
                        Width="Auto"
                        Binding="{Binding ValuesDisplay}" />

                    <DataGridTextColumn
                        Header="Alarm Count"
                        Binding="{Binding AlarmCount}" />

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

        <GroupBox Header="Statistics results:"
          Grid.Row="3"
          Margin="0,10,0,10">

            <DataGrid
                AutoGenerateColumns="True"
                ItemsSource="{Binding Results}" />

        </GroupBox>

    </Grid>
</Window>