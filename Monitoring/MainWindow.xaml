<Window x:Class="Monitoring.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monitoring"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="IoT Monitoring Dashboard" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2C3E50" Margin="0,0,0,15" Height="50">
            <TextBlock Text="IoT MONITORING DASHBOARD" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="15,0,30,0" FontSize="16"/>
            <Button Content="↩ Undo" Command="{Binding UndoCommand}" Width="80" Margin="5" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
            <Button Content="↪ Redo" Command="{Binding RedoCommand}" Width="80" Margin="5" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Sensor Management" Margin="0,0,10,0" Padding="5" FontWeight="Bold">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍 Search Sensors: " VerticalAlignment="Center" FontWeight="Normal" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchSensorText, UpdateSourceTrigger=PropertyChanged}" Height="23" FontWeight="Normal"/>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Sensors}" SelectedItem="{Binding SelectedSensor}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*"/>
                            <DataGridTextColumn Header="Min Val" Binding="{Binding MinValue}" Width="60"/>
                            <DataGridTextColumn Header="Max Val" Binding="{Binding MaxValue}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock Text="Sensor Data (Form):" Foreground="#34495E" Margin="0,0,0,5"/>
                        <UniformGrid Columns="2" Rows="3">
                            <StackPanel Margin="2">
                                <TextBlock Text="Name:" FontSize="11" FontWeight="Normal"/>
                                <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Height="23"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Type:" FontSize="11" FontWeight="Normal"/>
                                <TextBox Text="{Binding EditType, UpdateSourceTrigger=PropertyChanged}" Height="23"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Location:" FontSize="11" FontWeight="Normal"/>
                                <TextBox Text="{Binding EditLocation, UpdateSourceTrigger=PropertyChanged}" Height="23"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Minimum Value:" FontSize="11" FontWeight="Normal"/>
                                <TextBox Text="{Binding EditMin, UpdateSourceTrigger=PropertyChanged}" Height="23"/>
                            </StackPanel>
                            <StackPanel Margin="2">
                                <TextBlock Text="Maximum Value:" FontSize="11" FontWeight="Normal"/>
                                <TextBox Text="{Binding EditMax, UpdateSourceTrigger=PropertyChanged}" Height="23"/>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="➕ Add New" Command="{Binding AddSensorCommand}" Width="110" Height="28" Margin="5" Background="#27AE60" Foreground="White"/>
                            <Button Content="✏ Edit Selected" Command="{Binding UpdateSensorCommand}" Width="130" Height="28" Margin="5" Background="#F39C12" Foreground="White"/>
                            <Button Content="❌ Remove Sensor" Command="{Binding RemoveSensorCommand}" Width="110" Height="28" Margin="5" Background="#C0392B" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Telemetry and State Pattern" FontWeight="Bold">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍 Search Telemetry: " VerticalAlignment="Center" FontWeight="Normal" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchTelemetryText, UpdateSourceTrigger=PropertyChanged}" Height="23" FontWeight="Normal"/>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Telemetries}" SelectedItem="{Binding SelectedTelemetry}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sensor ID" Binding="{Binding Telemetry.SensorId}" Width="110"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Telemetry.Value}" Width="70"/>
                            <DataGridTextColumn Header="Current Status" Binding="{Binding Telemetry.Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,10" Background="#EAEDED" >
                        <TextBlock Text="State Change Simulation" HorizontalAlignment="Center" Margin="0,5,0,5" Foreground="#2C3E50"/>
                        <Button Content="🔄 Trigger Next State" Command="{Binding NextStateCommand}" 
                                Height="30" Background="#8E44AD" Foreground="White" FontWeight="Bold" Margin="5,0,5,5"/>
                        <TextBlock Text="Sequence: Stable -> Alarm -> Error -> Unactive -> Stable" 
                                   HorizontalAlignment="Center" FontSize="10" Margin="0,0,0,5" Foreground="Gray"/>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <lvc:PieChart Grid.Column="0"
                  Series="{Binding Series}" />

                        <StackPanel Grid.Column="1"
                Margin="10,0,0,0"
                VerticalAlignment="Center">

                            <TextBlock Text="Legend"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   Foreground="#2C3E50"/>

                            <ItemsControl ItemsSource="{Binding Series}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">

                                            <Rectangle Width="12" Height="12" Margin="0,0,8,0">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Fill" Value="Gray"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Name}" Value="Stable">
                                                                <Setter Property="Fill" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="Alarm">
                                                                <Setter Property="Fill" Value="Orange"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="Error">
                                                                <Setter Property="Fill" Value="Red"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="Unactive">
                                                                <Setter Property="Fill" Value="Gray"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>

                                            <TextBlock Text="{Binding Name}"
                                                 VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>